# Firebase Configuration
# Get these from Firebase Console > Project Settings > General
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_firebase_app_id

# Firebase Emulators (for local development)
# Set to "true" to use Firebase emulators instead of production
VITE_USE_FIREBASE_EMULATORS=false

# Google Gemini AI API Key (optional - for AI Coach feature)
# NOTE: This key should be set in Supabase Edge Function secrets, not here.
# GEMINI_API_KEY=your_gemini_api_key_here

# Resend API Key (for transactional emails)
# NOTE: This key should be set in Supabase Edge Function secrets, not here.
# Get your API key from: https://resend.com/api-keys
# Free tier: 100 emails/day, 3,000 emails/month
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Supabase Configuration
VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Sentry Error Tracking (for production monitoring)
# Get your DSN from: https://sentry.io/settings/projects/
# Free tier: 10,000 events/month
VITE_SENTRY_DSN=https://your_sentry_dsn_here@sentry.io/project_id

# Supabase Service Role (For Administrative Scripts Only - DO NOT EXPOSE TO FRONTEND)
SERVICE_ROLE_KEY=your_service_role_key

# Admin Configuration
# Comma-separated list of admin emails
VITE_ADMIN_EMAILS=admin@example.com,owner@example.com

# Test Configuration
TEST_USER_PASSWORD=password123