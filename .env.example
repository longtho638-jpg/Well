# WellNexus RaaS License Key
# Get your license key at https://agencyos.vn/raas
RAAS_LICENSE_KEY=RAAS-1234567890-ABCD1234

# PayOS Payment Gateway
PAYOS_CLIENT_ID=your_payos_client_id
PAYOS_API_KEY=your_payos_api_key
PAYOS_CHECKSUM_KEY=your_payos_checksum_key

# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key

# RaaS Features (auto-enabled by license)
# adminDashboard: true  - Access to /admin routes
# payosAutomation: true - Automated PayOS payment flows
# premiumAgents: true   - Premium AI agents
# advancedAnalytics: true - Advanced analytics dashboard
