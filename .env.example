# ==============================================================================
# WELLNEXUS ENVIRONMENT VARIABLES
# ==============================================================================
# Copy this file to .env.local and fill in your actual values
# DO NOT commit .env.local to git!
# ==============================================================================

# ------------------------------------------------------------------------------
# 🔴 REQUIRED - Frontend (Vite)
# ------------------------------------------------------------------------------

# Supabase Configuration (Primary Backend)
# Get from: Supabase Dashboard → Settings → API
VITE_SUPABASE_URL=https://jcbahdioqoepvoliplqy.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Admin Configuration
# Comma-separated list of admin emails
VITE_ADMIN_EMAILS=wellnexusvn@gmail.com,doanhnhancaotuan@gmail.com,billwill.mentor@gmail.com

# RaaS License Key (REQUIRED for production admin access)
# Format: RAAS-{timestamp}-{hash}
# Example: RAAS-1709337600-a1b2c3d4e5f6
# Generate timestamp: date +%s (Unix) or use https://www.unixtimestamp.com/
# Contact AgencyOS for license key
VITE_RAAS_LICENSE_KEY=RAAS-XXXXXXXXXX-your-license-hash

# ------------------------------------------------------------------------------
# 🟡 OPTIONAL - Frontend (Vite)
# ------------------------------------------------------------------------------

# Sentry Error Tracking (Production Monitoring)
# Get your DSN from: https://sentry.io/settings/projects/
# Free tier: 10,000 events/month
VITE_SENTRY_DSN=https://your_sentry_dsn_here@sentry.io/project_id

# Web Push Notifications VAPID Keys (PWA)
# Generate with: npx web-push generate-vapid-keys
# Public key goes here (exposed to frontend)
VITE_VAPID_PUBLIC_KEY=your_vapid_public_key_here

# ------------------------------------------------------------------------------
# 🔒 SERVER-SIDE ONLY - Supabase Edge Functions Secrets
# ------------------------------------------------------------------------------
# IMPORTANT: These are NOT frontend environment variables!
# Set these using Supabase CLI or Dashboard → Settings → Edge Functions → Secrets
# DO NOT add VITE_ prefix to these!
# ------------------------------------------------------------------------------

# Google Gemini AI API Key (for AI Coach feature)
# Set via: supabase secrets set GEMINI_API_KEY="your-key"
# GEMINI_API_KEY=your_gemini_api_key_here

# Resend API Key (Transactional Emails)
# Get from: https://resend.com/api-keys
# Free tier: 100 emails/day, 3,000 emails/month
# Set via: supabase secrets set RESEND_API_KEY="re_xxx"
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Web Push Notifications VAPID Private Key (Server-side only)
# Generate with: npx web-push generate-vapid-keys
# Set via: supabase secrets set VAPID_PRIVATE_KEY="your-key"
# VAPID_PRIVATE_KEY=your_vapid_private_key_here

# PayOS Payment Gateway (Vietnam Payment Provider)
# Get credentials from PayOS Dashboard: https://payos.vn
# Go to: Dashboard → Tích hợp → Thông tin API
# Set via Supabase CLI:
#   supabase secrets set PAYOS_CLIENT_ID="your-client-id"
#   supabase secrets set PAYOS_API_KEY="your-api-key"
#   supabase secrets set PAYOS_CHECKSUM_KEY="your-checksum-key"
# PAYOS_CLIENT_ID=your-client-id
# PAYOS_API_KEY=your-api-key
# PAYOS_CHECKSUM_KEY=your-checksum-key

# PayOS Production Webhook Secret (RaaS License Required)
# This secret is only validated when RAAS_LICENSE_KEY is present
# Set via: supabase secrets set PAYOS_WEBHOOK_SECRET="your-secret"
# PAYOS_WEBHOOK_SECRET=your_webhook_secret_here

# Agent Reward Webhook Secret (Commission Distribution)
# Random secret string for webhook authentication
# Set via: supabase secrets set WEBHOOK_SECRET="your-random-string"
# WEBHOOK_SECRET=your-random-secret-string

# ------------------------------------------------------------------------------
# 🔧 DEVELOPMENT & TESTING
# ------------------------------------------------------------------------------

# Supabase Service Role (Administrative Scripts Only)
# ⚠️ WARNING: NEVER expose this to frontend (no VITE_ prefix)
# Get from: Supabase Dashboard → Settings → API → service_role key
SERVICE_ROLE_KEY=your_service_role_key_here

# Test Configuration
TEST_USER_PASSWORD=password123

# ------------------------------------------------------------------------------
# 📋 VERIFICATION CHECKLIST
# ------------------------------------------------------------------------------
# Before running the app, ensure:
# ✅ VITE_SUPABASE_URL is set
# ✅ VITE_SUPABASE_ANON_KEY is set
# ✅ VITE_RAAS_LICENSE_KEY is set (production only, optional for dev)
# ✅ Supabase migrations have been applied
# ✅ Supabase Edge Functions secrets configured (if using email/payment)
# ✅ Admin emails configured in VITE_ADMIN_EMAILS
# ------------------------------------------------------------------------------
