# Firebase Configuration
# Get these from Firebase Console > Project Settings > General
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_firebase_app_id

# Firebase Emulators (for local development)
# Set to "true" to use Firebase emulators instead of production
VITE_USE_FIREBASE_EMULATORS=false

# Google Gemini AI API Key (optional - for AI Coach feature)
# NOTE: This key should be set in Supabase Edge Function secrets, not here.
# GEMINI_API_KEY=your_gemini_api_key_here

# Resend API Key (for transactional emails)
# NOTE: This key should be set in Supabase Edge Function secrets, not here.
# Get your API key from: https://resend.com/api-keys
# Free tier: 100 emails/day, 3,000 emails/month
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Web Push Notifications VAPID Keys (for PWA push notifications)
# Generate keys with: npx web-push generate-vapid-keys
# Public key goes in frontend (VITE_VAPID_PUBLIC_KEY)
# Private key goes in backend/Edge Functions (VAPID_PRIVATE_KEY - DO NOT EXPOSE)
VITE_VAPID_PUBLIC_KEY=your_vapid_public_key_here
# VAPID_PRIVATE_KEY=your_vapid_private_key_here (Server-side only - add to Supabase secrets)

# Supabase Configuration
VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Sentry Error Tracking (for production monitoring)
# Get your DSN from: https://sentry.io/settings/projects/
# Free tier: 10,000 events/month
VITE_SENTRY_DSN=https://your_sentry_dsn_here@sentry.io/project_id

# Supabase Service Role (For Administrative Scripts Only - DO NOT EXPOSE TO FRONTEND)
SERVICE_ROLE_KEY=your_service_role_key

# Admin Configuration
# Comma-separated list of admin emails
VITE_ADMIN_EMAILS=doanhnhancaotuan@gmail.com,billwill.mentor@gmail.com

# Test Configuration
TEST_USER_PASSWORD=password123

# PayOS Payment Gateway Configuration
# IMPORTANT: PayOS credentials are stored in Supabase Secrets (server-side only)
#
# Get credentials from PayOS Dashboard:
#   1. Register at https://payos.vn and create a merchant account
#   2. Go to Dashboard > Tích hợp > Thông tin API
#   3. Copy Client ID, API Key, and Checksum Key
#
# Set using Supabase CLI:
#   supabase secrets set PAYOS_CLIENT_ID="your-client-id"
#   supabase secrets set PAYOS_API_KEY="your-api-key"
#   supabase secrets set PAYOS_CHECKSUM_KEY="your-checksum-key"
#
# DO NOT add VITE_PAYOS_* variables here - they expose secrets to the client!

# Agent Reward Webhook Secret (for commission distribution)
# Set via Supabase CLI:
#   supabase secrets set WEBHOOK_SECRET="your-random-secret-string"