{
  "name": "wellnexus-raas",
  "private": false,
  "version": "3.0.0-open-source",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "NODE_OPTIONS=--max-old-space-size=4096 vite build",
    "build:check": "NODE_OPTIONS=--max-old-space-size=4096 tsc --noEmit",
    "preview": "vite preview",
    "test": "vitest run",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src",
    "sitemap:generate": "node scripts/generate-sitemap.mjs",
    "i18n:validate": "node scripts/validate-i18n-keys.mjs",
    "i18n:extract": "node scripts/extract-translation-keys.mjs",
    "i18n:check": "node scripts/check-locale-coverage.mjs",
    "i18n:sync": "node scripts/sync-i18n-keys.mjs",
    "ship": "tsx scripts/ship.ts",
    "pretest": "pnpm i18n:validate",
    "prepare": "husky install || true",
    "build:skip-i18n": "NODE_OPTIONS=--max-old-space-size=4096 vite build --mode production",
    "build:analyze": "ANALYZE=true NODE_OPTIONS=--max-old-space-size=4096 vite build --mode production"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "3.0.50",
    "@ai-sdk/google": "^1.2.22",
    "@ai-sdk/openai": "^1.3.24",
    "@ai-sdk/react": "^1.2.12",
    "@hookform/resolvers": "^5.2.2",
    "@react-pdf/renderer": "^4.3.2",
    "@sentry/react": "^10.40.0",
    "@supabase/supabase-js": "^2.98.0",
    "ai": "^6.0.105",
    "dompurify": "^3.3.1",
    "framer-motion": "^11.18.2",
    "i18next": "^25.8.13",
    "i18next-browser-languagedetector": "^8.2.1",
    "lucide-react": "^0.563.0",
    "react": "^19.2.4",
    "react-d3-tree": "^3.6.6",
    "react-dom": "^19.2.4",
    "react-helmet-async": "^2.0.5",
    "react-hook-form": "^7.71.2",
    "react-i18next": "^16.5.4",
    "react-router-dom": "^6.30.3",
    "recharts": "^2.15.4",
    "zod": "^3.25.76",
    "zustand": "^4.5.7"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix --max-warnings=0 --no-warn-ignored"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^9.39.3",
    "@playwright/test": "^1.58.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "ajv": "6.12.6",
    "autoprefixer": "^10.4.27",
    "claudekit": "^0.9.4",
    "dotenv": "^17.3.1",
    "eslint": "^9.39.3",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "glob": "^13.0.6",
    "globals": "^17.4.0",
    "happy-dom": "^20.7.0",
    "husky": "^8.0.3",
    "jsdom": "^27.4.0",
    "lighthouse": "13.0.3",
    "lint-staged": "^16.3.1",
    "minimatch": "^10.2.4",
    "postcss": "^8.5.6",
    "rollup": "^4.59.0",
    "rollup-plugin-visualizer": "7.0.1",
    "sharp": "^0.34.5",
    "sharp-cli": "^5.2.0",
    "tailwindcss": "^3.4.19",
    "ts-morph": "^27.0.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-image-optimizer": "2.0.3",
    "vitest": "^4.0.18",
    "wrangler": "^4.24.0"
  },
  "pnpm": {
    "overrides": {
      "esbuild": "0.24.2"
    }
  }
}