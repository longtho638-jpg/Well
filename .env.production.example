# Production Environment Variables Template

# Supabase Production
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_production_anon_key_here

# AGI AI Providers (set at least one for agent features)
# Google Gemini — used by default for AGI ReAct loop
GOOGLE_GENERATIVE_AI_API_KEY=your_google_ai_api_key_here
# OpenAI — alternative provider
# OPENAI_API_KEY=your_openai_api_key_here
# Anthropic — alternative provider
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Feature Flags (optional)
VITE_ENABLE_AGENCYOS=true
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_ERROR_TRACKING=true

# Rate Limiting (optional)
VITE_COMMAND_RATE_LIMIT=10
VITE_COMMAND_RATE_WINDOW_MS=60000
